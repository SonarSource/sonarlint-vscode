{
    "compilerOptions": {
        "module": "commonjs",
        "moduleResolution": "node",
        "target": "es6",
        "outDir": "out",
        "lib": [
            "es6",
        ],
        "sourceMap": true,
        "rootDir": ".",
		"jsx": "react",
		"jsxFactory": "vscpp",
		"jsxFragmentFactory": "vscppf"
    },
    "exclude": [
        "node_modules",
        ".vscode-test",
        "its",
        "dogfood",
        "eslint-bridge"
    ]
}
